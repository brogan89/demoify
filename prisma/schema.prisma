// Demoify — GitHub for songs
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Better Auth core tables (email + password). Field names match Better Auth's
// expected schema; `username`, `displayName`, `avatarUrl` are added via the
// auth config `user.additionalFields`.
// ---------------------------------------------------------------------------

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Personal identity, shown on comments. Band-level identity, songs, and
  // credits now live on Band (a user joins bands via BandMembership). `username`
  // is kept only because Better Auth manages this table and the column is
  // NOT NULL + UNIQUE; it's no longer used for routing (Band.username is).
  username    String  @unique
  displayName String
  avatarUrl   String?

  sessions    Session[]
  accounts    Account[]
  memberships BandMembership[]
  comments    Comment[]
  projects    SongProject[] // songs this user created (SongProject.owner)
  likes       Like[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Demoify domain
// ---------------------------------------------------------------------------

// A band is the organization that owns the public identity (the URL handle),
// its songs, and its credit balance. Users join bands via BandMembership.
model Band {
  id          String   @id @default(cuid())
  // Public URL handle — the first segment of /[username]/[slug].
  username    String   @unique
  displayName String
  avatarUrl   String?
  // Short artist bio shown on the public profile page (/[username]).
  bio         String?
  // Social/website links shown on the public profile page, as a JSON object map
  // of `{ [platformKey]: url }` (e.g. {"instagram":"https://…"}). See src/lib/socials.ts.
  socialLinks String?
  // Credits balance. New bands start with enough for 10 free uploads (STARTING_CREDITS).
  credits     Int      @default(100)
  // Stripe Connect (Express) account that receives tips for this artist. Null
  // until the band sets up payouts. `payoutsEnabled` caches whether that account
  // can actually receive money (charges + payouts enabled), refreshed by the
  // Stripe `account.updated` webhook so we don't hit the API on every page.
  stripeAccountId String?
  payoutsEnabled  Boolean @default(false)
  createdAt   DateTime @default(now())

  memberships  BandMembership[]
  projects     SongProject[]
  transactions CreditTransaction[]
  tips         Tip[]

  @@map("band")
}

// Join table: which users belong to which bands, and with what role.
// role is "ADMIN" | "MANAGER" | "MEMBER" (SQLite has no enums — validated in app).
model BandMembership {
  id        String   @id @default(cuid())
  bandId    String
  band      Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([bandId, userId])
  @@index([userId])
  @@map("band_membership")
}

model SongProject {
  id          String   @id @default(cuid())
  bandId      String
  band        Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  // The user who created the song (for display / audit). Kept from the old
  // schema where it was the owner; the owning org is now `band`.
  // onDelete: Cascade means deleting this User deletes this song too, even if
  // the band has other members — guarded against in assertCanDeleteAccount
  // (src/lib/account-deletion.ts), the only enforcement point for that check.
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  // "PUBLIC" (anyone can view) | "PRIVATE" (band members only).
  visibility  String   @default("PUBLIC")
  // Optional curated genre + subgenre (see src/lib/genres.ts). Powers the Explore
  // filter. Stored denormalized since the option list is a fixed, curated set.
  genre       String?
  subgenre    String?
  createdAt   DateTime @default(now())
  // Lifetime plays, counted per song URL so they survive new version uploads.
  playCount   Int      @default(0)

  versions SongVersion[]
  comments Comment[]
  likes    Like[]

  // Permanent URL is /[username]/[slug] — slug unique per band
  @@unique([bandId, slug])
  @@index([genre])
  @@map("song_project")
}

// A user's like on a (public) song. The liked set is the user's /library playlist;
// like count drives the Explore "Popular" sort.
model Like {
  id        String      @id @default(cuid())
  projectId String
  project   SongProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@map("song_like")
}

// Ledger of credit changes — purchases (+), uploads (-), and engagement rewards (+).
// Source of truth for the balance is Band.credits; this table is for history and
// idempotency (webhook replays, and once-per-song engagement grants).
model CreditTransaction {
  id              String   @id @default(cuid())
  bandId          String
  band            Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  delta           Int // positive = added, negative = spent
  reason          String // "upload" | "purchase" | "like" | "comment" | "play"
  stripeSessionId String?  @unique
  // Engagement grants only: the user who engaged and the song (projectId) they
  // engaged with. Null for upload/purchase rows. The unique constraint caps each
  // engager to one reward per song per action.
  userId          String?
  refId           String?
  createdAt       DateTime @default(now())

  @@unique([userId, reason, refId])
  @@index([bandId])
  @@map("credit_transaction")
}

// A real-money tip from a user to an artist (Band), paid via Stripe Connect with
// a 90/10 split: 90% transfers to the artist's connected account, 10% is the
// platform application fee. Stripe moves the money — this row is the receipt /
// history and the idempotency guard for the webhook (unique stripeSessionId).
model Tip {
  id              String   @id @default(cuid())
  // Recipient artist.
  bandId          String
  band            Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  // Who tipped (login required to tip; nullable so a deleted user doesn't break history).
  tipperUserId    String?
  // The song the tip was sent from, for context (optional).
  projectId       String?
  amountCents     Int // gross amount charged
  feeCents        Int // platform's 10%
  artistCents     Int // artist's 90%
  currency        String   @default("usd")
  status          String   @default("pending") // "pending" | "paid"
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  @@index([bandId])
  @@map("tip")
}

// ---------------------------------------------------------------------------
// Federation — sharing public tracks across self-hosted instances.
//
// A "hub" instance (e.g. demoify.app) accepts track submissions from registered
// self-hosted instances and surfaces approved ones in its Explore feed. Only
// metadata is stored: the audio and the song/artist pages live on the origin
// instance's own storage and site, so nothing is copied or re-hosted here.
// These tables are inert unless FEDERATION_HUB_ENABLED is set.
// ---------------------------------------------------------------------------

// A self-hosted instance permitted to submit tracks to this hub. Provisioned by
// the hub operator (see scripts/federation.ts), which stores only the SHA-256 of
// the shared submission token.
model FederatedInstance {
  id        String   @id @default(cuid())
  name      String
  baseUrl   String   @unique // origin URL, e.g. https://music.example.com
  tokenHash String // sha-256 hex of the bearer token used to authenticate submissions
  trusted   Boolean  @default(false) // true → submissions auto-approve; else land as "pending"
  createdAt DateTime @default(now())

  tracks ExternalTrack[]

  @@map("federated_instance")
}

// A public track mirrored from a federated instance. `audioUrl`/`trackUrl`/
// `artistUrl` are absolute URLs on the origin; play counts and like counts are
// periodically-refreshed snapshots (this hub has no local engagement for them).
model ExternalTrack {
  id          String            @id @default(cuid())
  instanceId  String
  instance    FederatedInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  remoteId    String // the SongProject id on the origin instance
  title       String
  artistName  String
  artistUrl   String // origin artist profile URL
  trackUrl    String // origin song page URL
  audioUrl    String // absolute audio URL on origin storage
  genre       String?
  subgenre    String?
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  playCount   Int      @default(0) // snapshot from origin
  likeCount   Int      @default(0) // snapshot from origin
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([instanceId, remoteId])
  @@index([status, genre])
  @@map("external_track")
}

model SongVersion {
  id            String      @id @default(cuid())
  projectId     String
  project       SongProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNumber Int
  audioUrl      String
  changelog     String?
  duration      Float?
  uploadedAt    DateTime    @default(now())

  comments Comment[]

  @@unique([projectId, versionNumber])
  @@map("song_version")
}

// A comment on a song. Tagged with the version it was written against so feedback
// stays anchored to a specific revision even after newer versions are uploaded.
model Comment {
  id        String      @id @default(cuid())
  projectId String
  project   SongProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId String
  version   SongVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  // Optional playback position (whole seconds) this comment is anchored to.
  // Null means a general comment not tied to a moment in the track.
  timestampSeconds Int?
  createdAt DateTime    @default(now())

  @@index([projectId])
  @@map("comment")
}
