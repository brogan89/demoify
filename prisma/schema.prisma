// Demoify — GitHub for songs
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Better Auth core tables (email + password). Field names match Better Auth's
// expected schema; `username`, `displayName`, `avatarUrl` are added via the
// auth config `user.additionalFields`.
// ---------------------------------------------------------------------------

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Personal identity, shown on comments. Band-level identity, songs, and
  // credits now live on Band (a user joins bands via BandMembership). `username`
  // is kept only because Better Auth manages this table and the column is
  // NOT NULL + UNIQUE; it's no longer used for routing (Band.username is).
  username    String  @unique
  displayName String
  avatarUrl   String?

  sessions    Session[]
  accounts    Account[]
  memberships BandMembership[]
  comments    Comment[]
  projects    SongProject[] // songs this user created (SongProject.owner)

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Demoify domain
// ---------------------------------------------------------------------------

// A band is the organization that owns the public identity (the URL handle),
// its songs, and its credit balance. Users join bands via BandMembership.
model Band {
  id          String   @id @default(cuid())
  // Public URL handle — the first segment of /[username]/[slug].
  username    String   @unique
  displayName String
  avatarUrl   String?
  // Credits balance. New bands start with enough for 3 free uploads (STARTING_CREDITS).
  credits     Int      @default(150)
  createdAt   DateTime @default(now())

  memberships  BandMembership[]
  projects     SongProject[]
  transactions CreditTransaction[]

  @@map("band")
}

// Join table: which users belong to which bands, and with what role.
// role is "ADMIN" | "MANAGER" | "MEMBER" (SQLite has no enums — validated in app).
model BandMembership {
  id        String   @id @default(cuid())
  bandId    String
  band      Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([bandId, userId])
  @@index([userId])
  @@map("band_membership")
}

model SongProject {
  id          String   @id @default(cuid())
  bandId      String
  band        Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  // The user who created the song (for display / audit). Kept from the old
  // schema where it was the owner; the owning org is now `band`.
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  // "PUBLIC" (anyone can view) | "PRIVATE" (band members only).
  visibility  String   @default("PUBLIC")
  createdAt   DateTime @default(now())
  // Lifetime plays, counted per song URL so they survive new version uploads.
  playCount   Int      @default(0)

  versions SongVersion[]
  comments Comment[]

  // Permanent URL is /[username]/[slug] — slug unique per band
  @@unique([bandId, slug])
  @@map("song_project")
}

// Ledger of credit changes — purchases (+) and uploads (-). Source of truth for
// the balance is Band.credits; this table is for history and webhook idempotency.
model CreditTransaction {
  id              String   @id @default(cuid())
  bandId          String
  band            Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  delta           Int // positive = added, negative = spent
  reason          String // "upload" | "purchase"
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  @@index([bandId])
  @@map("credit_transaction")
}

model SongVersion {
  id            String      @id @default(cuid())
  projectId     String
  project       SongProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNumber Int
  audioUrl      String
  changelog     String?
  duration      Float?
  uploadedAt    DateTime    @default(now())

  comments Comment[]

  @@unique([projectId, versionNumber])
  @@map("song_version")
}

// A comment on a song. Tagged with the version it was written against so feedback
// stays anchored to a specific revision even after newer versions are uploaded.
model Comment {
  id        String      @id @default(cuid())
  projectId String
  project   SongProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId String
  version   SongVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime    @default(now())

  @@index([projectId])
  @@map("comment")
}
