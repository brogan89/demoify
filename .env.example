# ---------------------------------------------------------------------------
# Required — the app will not start without these.
# ---------------------------------------------------------------------------

# Postgres connection string used by Prisma and the app.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/demoify"

# Better Auth signing secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL Better Auth uses to build callback/cookie URLs.
BETTER_AUTH_URL="http://localhost:3000"

# Public app URL exposed to the browser (used for absolute links/redirects).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Optional — social login. Each provider is enabled only when both of its
# values are present.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Optional — Cloudflare R2 (song uploads). Uploads are disabled until all
# five values are set.
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ---------------------------------------------------------------------------
# Optional — Stripe (credit purchases). Payments are disabled until set.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Self-hosting — the credit economy. On by default (uploads cost credits). Set
# to "false" to make uploads free and unlimited and hide all credit UI; useful
# when you host your own storage and don't want to meter uploads.
# ---------------------------------------------------------------------------
CREDITS_ENABLED="true"

# ---------------------------------------------------------------------------
# Optional — Federation. Submit this instance's public tracks to a central hub
# (e.g. demoify.app) so they appear in its shared Explore feed. Both values are
# required to enable pushing; the hub operator issues you a token.
# ---------------------------------------------------------------------------
FEDERATION_HUB_URL=""
FEDERATION_TOKEN=""

# Set to "true" only on a hub instance that should ACCEPT track submissions from
# other instances and show approved ones in its own Explore.
FEDERATION_HUB_ENABLED="false"

# ---------------------------------------------------------------------------
# Optional — version label shown in the site footer. CI sets this automatically
# on deploy (and tags the commit to match); leave it unset locally (shows "dev").
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_VERSION=""
